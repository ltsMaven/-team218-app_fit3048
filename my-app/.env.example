# Auth0 Authentication
AUTH0_DOMAIN=insert_your_auth0_domain_here
AUTH0_CLIENT_ID=insert_your_auth0_client_id_here
AUTH0_CLIENT_SECRET=insert_your_auth0_client_secret_here
AUTH0_SECRET=insert_a_32_byte_hex_secret_here
APP_BASE_URL=http://localhost:3000
AUTH0_ADMIN_EMAIL=admin@example.com
AUTH0_ADMIN_ROLE=admin
AUTH0_ROLES_CLAIM=https://your-domain.example.com/roles

# Supabase Connection
NEXT_PUBLIC_SUPABASE_URL=insert_your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=insert_your_anon_key_here

# Calendly Connection
CALENDLY_API_TOKEN=insert_your_calendly_token_here
